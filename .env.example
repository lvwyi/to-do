# ============================================================
# DashScope API 配置（阿里云百炼）
# ============================================================
# 1. 申请 API Key：https://dashscope.console.aliyun.com/apiKey
# 2. 复制此文件为 .env.local
#    cp .env.example .env.local
# 3. 将你的 API Key 填入 VITE_DASHSCOPE_API_KEY
# 4. 启动开发服务器：npm run dev
#
# 注意：环境变量必须以 VITE_ 开头才能被 Vite 注入到前端代码中。
#       生产环境需通过反向代理转发 /api/dashscope 请求，
#       确保 API Key 不会暴露给浏览器。

# === DashScope API Key ===
# 必填！在阿里云百炼控制台创建
VITE_DASHSCOPE_API_KEY=dash-sk-04fcc396b6ed40399f0d6ca6e91cb74c

# === AI 模型选择 ===
# qwen-turbo  （快速、便宜）
# qwen-plus   （平衡，默认推荐）
# qwen-max    （最强但较慢）
VITE_DASHSCOPE_MODEL=deepseek-v4-flash
# === API 端点地址 ===
# 一般不需要修改，除非使用其他兼容接口
VITE_API_BASE_URL=https://api.deepseek.com/anthropic
